{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File .claude/hooks/log-py-edits.ps1",
            "statusMessage": "Logging .py edits"
          }
        ]
      }
    ]
  }
}
